{
  "name": "cometx-hybrid",
  "version": "0.1.0",
  "description": "CometX Hybrid Browser — Local Chromium + Local LLM",
  "main": "electron/main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:linux": "electron-builder --linux",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac"
  },
  "dependencies": {
    "node-llama-cpp": "^3.2.0"
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.gratech.cometx",
    "productName": "CometX",
    "directories": {
      "output": "dist"
    },
    "files": [
      "electron/**/*",
      "ui/**/*",
      "models/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "models/",
        "to": "models/",
        "filter": ["**/*.gguf"]
      }
    ],
    "linux": {
      "target": ["AppImage", "deb"],
      "category": "Network"
    },
    "win": {
      "target": ["nsis", "portable"]
    },
    "mac": {
      "target": ["dmg"],
      "category": "public.app-category.utilities"
    }
  }
}
